{
  "expo": {
    "name": "iVOD",
    "slug": "ivod",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "ivod",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#00050d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ci.ivod.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#00050d"
      },
      "package": "ci.ivod.app"
    },
    "plugins": [
      "expo-router",
"expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#e6007e"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
