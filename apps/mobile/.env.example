# URL de l'API IVOD (sans slash final)
#
# ⚠️ Sur TÉLÉPHONE PHYSIQUE, localhost ne fonctionne PAS.
# Utilisez l'IP LAN de votre Mac (ifconfig → en0 → inet)
#
# Simulateur iOS     : http://localhost:3000/api/v1
# Émulateur Android  : http://10.0.2.2:3000/api/v1
# Appareil physique  : http://192.168.1.XX:3000/api/v1
EXPO_PUBLIC_API_URL=http://192.168.1.15:3000/api/v1

# Optionnel — token push Expo (build EAS / production)
# EXPO_PUBLIC_EAS_PROJECT_ID=
