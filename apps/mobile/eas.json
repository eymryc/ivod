{
  "cli": {
    "version": ">= 14.0.0",
    "requireCommit": true
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000/api/v1",
        "EXPO_PUBLIC_WEB_URL": "http://localhost:3001",
        "EXPO_PUBLIC_MINIO_ASSETS_BUCKET": "ivod-assets",
        "EXPO_PUBLIC_MINIO_VIDEOS_BUCKET": "ivod-videos"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://ivod-preprod-srv01.xselcloud.com/api/v1",
        "EXPO_PUBLIC_WEB_URL": "https://ivod-preprod-srv01.xselcloud.com",
        "EXPO_PUBLIC_MINIO_ASSETS_BUCKET": "ivod-assets",
        "EXPO_PUBLIC_MINIO_VIDEOS_BUCKET": "ivod-videos"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://ivod-preprod-srv01.xselcloud.com/api/v1",
        "EXPO_PUBLIC_WEB_URL": "https://ivod-preprod-srv01.xselcloud.com",
        "EXPO_PUBLIC_MINIO_ASSETS_BUCKET": "ivod-assets",
        "EXPO_PUBLIC_MINIO_VIDEOS_BUCKET": "ivod-videos"
      },
      "ios": {
        "credentialsSource": "remote"
      },
      "android": {
        "credentialsSource": "remote",
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "contact@ivod.africa",
        "ascAppId": "XXXXXXXXXX",
        "appleTeamId": "XXXXXXXXXX"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "production"
      }
    }
  }
}
