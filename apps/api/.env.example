# ─── Base de données ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://ivod:password@localhost:5432/ivod"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="secret_tres_long_et_aleatoire_minimum_32_chars"
JWT_EXPIRES_IN="7d"

# ─── Upload vidéo : minio (chaîne interne presign) ou mux (SaaS) ──────────────
# minio | mux — défaut: minio. Pour revenir à Mux uniquement : mux (+ tokens ci‑dessous).
VIDEO_UPLOAD_PROVIDER="minio"

# ─── Mux ──────────────────────────────────────────────────────────────────────
MUX_TOKEN_ID="votre_mux_token_id"
MUX_TOKEN_SECRET="votre_mux_token_secret"
MUX_WEBHOOK_SECRET="votre_mux_webhook_secret"
MUX_SIGNING_KEY_ID="votre_signing_key_id"
MUX_SIGNING_PRIVATE_KEY="votre_signing_private_key"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PREMIUM="price_xxxx"
STRIPE_PRICE_PREMIUM_PLUS="price_xxxx"

# ─── CinetPay ─────────────────────────────────────────────────────────────────
CINETPAY_API_KEY="votre_api_key"
CINETPAY_SITE_ID="votre_site_id"

# ─── Redis (BullMQ : workers probe/transcode) ─────────────────────────────────
# Priorité: REDIS_URL si défini, sinon Upstash ci-dessous.
# Avec Redis du docker-compose à la racine du repo : redis/redis_data sur le port 6379
REDIS_URL="redis://localhost:6379"

# ─── Redis (Upstash, prod / sans Docker local) ───────────────────────────────
UPSTASH_REDIS_URL="rediss://..."
UPSTASH_REDIS_TOKEN="votre_token"

# ─── Upstash Redis REST (OTP store — scalable multi-instance) ─────────────────
# Activer en production pour stocker les OTP dans Redis au lieu de la mémoire.
# Dashboard Upstash → Data Browser → REST API → copier URL + Token.
# Si absent, le store OTP reste en mémoire (dev local uniquement).
UPSTASH_REDIS_REST_URL="https://votre-endpoint.upstash.io"
UPSTASH_REDIS_REST_TOKEN="votre_rest_token"

# ─── Transcode ladder (HLS) ────────────────────────────────────────────────────
# Preset bitrate ladder:
# - mobile: débit réduit (réseaux mobiles / coûts egress bas)
# - balanced: compromis qualité/coût (défaut)
# - tv: qualité plus élevée (écrans TV / fibre)
TRANSCODE_LADDER_PRESET="balanced"
# Hauteur max autorisée dans le ladder dynamique. Bonne pratique locale/prod CPU: 1080 ou 2160.
# 2160 active le profil 4K si la source le permet. (8K non activé dans ce pipeline)
TRANSCODE_MAX_HEIGHT="2160"
# Chemins des binaires vidéo (optionnel). Utile si ffmpeg/ffprobe ne sont pas dans le PATH système.
# FFMPEG_PATH="/opt/homebrew/bin/ffmpeg"
# FFPROBE_PATH="/opt/homebrew/bin/ffprobe"

# ─── SMTP (emails) ────────────────────────────────────────────────────────────
MAIL_MAILER="smtp"
MAIL_HOST="server221.web-hosting.com"
MAIL_PORT=465
MAIL_USERNAME="noreply@folioas.com"
MAIL_PASSWORD="your_password"
MAIL_FROM_ADDRESS="noreply@folioas.com"
MAIL_FROM_NAME="iVOD"
MAIL_ADMIN_NOTIFICATION_EMAILS="admin1@example.com,admin2@example.com"
APP_NAME="iVOD"

# ─── OneSignal (push) ─────────────────────────────────────────────────────────
ONESIGNAL_APP_ID="votre_app_id"
ONESIGNAL_API_KEY="votre_api_key"

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3001"
# Origine publique de l’API (lecture HLS en mode proxy : rewrite des playlists vers /api/v1/videos/hls-proxy/...)
API_PUBLIC_URL="http://localhost:3000"
# Lecture MinIO : proxy (défaut, recommandé) ou presign (URL master seule ; segments relatifs souvent cassés).
HLS_PLAYBACK_MODE="proxy"
# Optionnel : secret dédié aux jetons `pt` du proxy HLS (sinon JWT_SECRET).
# HLS_PLAYBACK_SECRET="autre_secret_long"
NODE_ENV="development"
PORT=3000

# ─── MinIO (S3-compatible) ─────────────────────────────────────────────────────
# Local: docker-compose.yml à la racine (service minio). Aligner clés sur MINIO_ROOT_USER / MINIO_ROOT_PASSWORD du compose.
MINIO_ENDPOINT="http://localhost:9000"
# Endpoint utilisé pour signer les URL PUT pour le navigateur (optionnel).
# En Docker API + web local: MINIO_ENDPOINT interne peut être `http://minio:9000`,
# mais MINIO_PRESIGN_ENDPOINT doit rester accessible depuis le navigateur (ex: localhost).
# MINIO_PRESIGN_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="ivod"
# URL publique utilisée par le front pour afficher les images (bucket en download anonyme)
MINIO_PUBLIC_BASE_URL="http://localhost:9000/ivod"
