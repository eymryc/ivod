# apps/api/.env — copier : cp apps/api/.env.example apps/api/.env
# Racine .env = Postgres / Redis / MinIO / ports uniquement (voir docs/ENV.md)

# ─── Base de données ─────────────────────────────────────────────────────────
# Local : localhost | Docker : surchargé par compose (postgres:5432)
DATABASE_URL=postgresql://ivod:ivod@localhost:5432/ivod

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001
API_PUBLIC_URL=http://localhost:3000/api/v1

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-minimum-32-chars
JWT_REFRESH_SECRET=change-me-refresh-minimum-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MinIO ───────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PUBLIC_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_VIDEOS=ivod-videos
MINIO_BUCKET_ASSETS=ivod-assets

# ─── Pipeline vidéo (dev = même ladder que prod ; VIDEO_FAST_MODE pour tests rapides) ─
VIDEO_TWO_PHASE=true
VIDEO_CPU_PARALLEL=2
VIDEO_WORKER_CONCURRENCY=1
VIDEO_JOB_LOCK_MS=3600000
VIDEO_JOB_LOCK_RENEW_MS=300000
VIDEO_SINGLE_PASS_LADDER=true
# HLS segments: ts (default) | fmp4 (CMAF)
# VIDEO_HLS_SEGMENT_TYPE=ts
# Webhooks pipeline (optionnel, URLs séparées par virgule)
# VIDEO_WEBHOOK_URLS=https://example.com/hooks/ivod-video
# VIDEO_WEBHOOK_SECRET=change-me
# VIDEO_CDN_BASE_URL=https://cdn.example.com/api/v1
# VIDEO_PLAYBACK_TOKEN_TTL_SEC=900
# LIVE_RTMP_URL=rtmp://localhost:1935/live
# LIVE_HLS_PLAYBACK_URL=
# VIDEO_DEV_PROFILES=480p,720p
# VIDEO_FAST_MODE=true
# VIDEO_HW_ACCEL=none
# FFMPEG_PATH=ffmpeg
# FFPROBE_PATH=ffprobe

# ─── SMTP ────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@ivod.africa
MAIL_FROM_NAME=iVOD
APP_NAME=iVOD

# ─── Paystack (dashboard → Settings → API Keys — copier les clés ENTIÈRES) ───
# Ne pas laisser sk_test_... : Paystack renvoie "Invalid key"
PAYSTACK_SECRET_KEY=sk_test_collez_ici_la_secret_key_complete
PAYSTACK_PUBLIC_KEY=pk_test_collez_ici_la_public_key_complete
ALLOW_PAYMENT_SIMULATION=false


# ─── Tests e2e (optionnel) ───────────────────────────────────────────────────
# TEST_MODE=true
# TEST_API_URL=http://localhost:3002
