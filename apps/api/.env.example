# apps/api/.env.example — copier : cp apps/api/.env.example apps/api/.env
# ⚠️  Ne jamais committer apps/api/.env (contient des secrets)

# ─── Base de données ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ivod:ivod@localhost:5432/ivod

# Identifiants du conteneur Postgres lui-même (docker-compose.prod.yml) — PAS
# de valeur par défaut volontairement (contrairement au docker-compose.dev.yml
# qui a des fallbacks ivod/ivod) : en prod, si ces variables sont absentes de
# CE fichier, Postgres démarre avec des identifiants vides plutôt que de
# retomber silencieusement sur un mot de passe faible. DATABASE_URL ci-dessus
# doit rester cohérent avec ces valeurs.
POSTGRES_USER=ivod
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=ivod

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# API_PUBLIC_URL : laisser VIDE/commenté en dev — l'API dérive sa base publique du Host
# de chaque requête (web sur localhost, mobile sur son IP LAN reçoivent chacun une URL
# de lecture valide). Ne définir qu'en production, derrière un domaine fixe (CDN/proxy).
# API_PUBLIC_URL=https://api.ivod.example.com/api/v1

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 48
JWT_SECRET=change-me-minimum-32-chars
JWT_REFRESH_SECRET=change-me-refresh-minimum-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Secret DÉDIÉ pour les tokens de lecture HLS — DOIT être différent de JWT_SECRET
# Générer avec : openssl rand -base64 48
PLAYBACK_JWT_SECRET=change-me-playback-minimum-32-chars

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Stockage objet (MinIO self-hosted OU S3 externe) ─────────────────────────
# Identifiants root du conteneur MinIO lui-même (docker-compose.prod.yml) —
# self-hosted uniquement (ignoré en mode S3 externe/Wasabi, voir plus bas).
# Pas de valeur par défaut en prod pour la même raison que POSTGRES_* ci-dessus.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-strong-password

# Mode dev / self-hosted (défaut) :
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PUBLIC_PORT=9000
MINIO_USE_SSL=false
# MINIO_PUBLIC_USE_SSL : distinct de MINIO_USE_SSL (trafic interne Docker,
# toujours en clair) — c'est le flag des presigned URLs données au navigateur
# (upload direct depuis /studio, avatars, bannières...). EN PRODUCTION,
# mettre à true + MINIO_PUBLIC_ENDPOINT=<domaine> + MINIO_PUBLIC_PORT=443,
# sinon le navigateur bloque l'upload en "mixed content" (page https, URL
# presignée http). Nginx route /ivod-videos/ et /ivod-assets/ en clair vers
# minio:9000 en interne — voir apps/api/nginx/nginx.prod.conf.
MINIO_PUBLIC_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_VIDEOS=ivod-videos
MINIO_BUCKET_ASSETS=ivod-assets
# MINIO_REGION=us-east-1         # laisser vide en dev MinIO (autodétecté)
# MINIO_SKIP_BUCKET_INIT=false   # true si les buckets existent déjà (S3 externe)

# Mode production Wasabi (décommenter + utiliser docker-compose.s3-external.yml) :
# MINIO_ENDPOINT=s3.eu-west-1.wasabisys.com
# MINIO_PORT=443
# MINIO_PUBLIC_ENDPOINT=s3.eu-west-1.wasabisys.com
# MINIO_PUBLIC_PORT=443
# MINIO_USE_SSL=true
# MINIO_ACCESS_KEY=<wasabi-access-key>
# MINIO_SECRET_KEY=<wasabi-secret-key>
# MINIO_REGION=eu-west-1
# MINIO_SKIP_BUCKET_INIT=true
# MINIO_BUCKET_VIDEOS=ivod-videos-prod
# MINIO_BUCKET_ASSETS=ivod-assets-prod

# CDN Cloudflare devant Wasabi (recommandé en prod pour HLS) :
# VIDEO_CDN_BASE_URL=https://cdn.ivod.africa
# → Cloudflare : ajouter un CNAME cdn.ivod.africa → s3.eu-west-1.wasabisys.com
# → Règle de cache : *.ts = cache long, *.m3u8 = cache court (2s)

# ─── Pipeline vidéo ───────────────────────────────────────────────────────────
VIDEO_TWO_PHASE=true
VIDEO_CPU_PARALLEL=2
VIDEO_WORKER_CONCURRENCY=2
VIDEO_FFMPEG_THREADS=4
VIDEO_JOB_LOCK_MS=3600000
VIDEO_JOB_LOCK_RENEW_MS=300000
VIDEO_SINGLE_PASS_LADDER=true
# VIDEO_HLS_SEGMENT_TYPE=ts
# VIDEO_PLAYBACK_TOKEN_TTL_SEC=900
# TTL jeton téléchargement HLS offline (segments, défaut 4 h)
# DOWNLOAD_PLAYBACK_TOKEN_TTL_SEC=14400
# VIDEO_CDN_BASE_URL=
# VIDEO_WEBHOOK_URLS=
# VIDEO_WEBHOOK_SECRET=
# VIDEO_DEV_PROFILES=480p,720p
# VIDEO_FAST_MODE=false
# VIDEO_HW_ACCEL=none
# FFMPEG_PATH=ffmpeg
# FFPROBE_PATH=ffprobe

# ─── Live streaming (optionnel) ───────────────────────────────────────────────
# LIVE_RTMP_URL=rtmp://localhost:1935/live
# LIVE_HLS_PLAYBACK_URL=

# ─── SMTP ─────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@ivod.africa
MAIL_FROM_NAME=iVOD
APP_NAME=iVOD

# ─── Paystack ─────────────────────────────────────────────────────────────────
# Dashboard Paystack → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_test_collez_ici
PAYSTACK_PUBLIC_KEY=pk_test_collez_ici
ALLOW_PAYMENT_SIMULATION=false

# ─── Sentry (monitoring erreurs) ──────────────────────────────────────────────
# Laisser vide en dev — Sentry ne s'initialise que si SENTRY_DSN est défini
# Dashboard Sentry → Settings → Projects → Client Keys (DSN)
# SENTRY_DSN=https://xxxxxx@oxxxxxx.ingest.sentry.io/xxxxxxx
# SENTRY_RELEASE=1.0.0

# ─── Monitoring Grafana ───────────────────────────────────────────────────────
# Mot de passe admin Grafana (apps/monitoring/docker-compose.monitoring.yml)
# GRAFANA_PASSWORD=changeme_in_production
# GRAFANA_ROOT_URL=https://monitoring.ivod.africa

# ─── Production — domaine public API ──────────────────────────────────────────
# API_PUBLIC_URL=https://api.ivod.africa/api/v1
# VIDEO_CDN_BASE_URL=https://cdn.ivod.africa
# VIDEO_PLAYBACK_TOKEN_TTL_SEC=900

# ─── Production — build args du web (apps/web/docker-compose.prod.yml) ───────
# Lus depuis CE fichier (apps/api/.env), pas apps/web/.env — voir le commentaire
# en tête de apps/web/docker-compose.prod.yml pour le pourquoi. Baked dans le
# bundle JS du front au build (docker compose ... build web) — nécessite un
# rebuild (pas juste un restart) pour prendre effet après modification.
# NEXT_PUBLIC_API_URL=https://ivod-preprod-srv01.xselcloud.com/api/v1
# NEXT_PUBLIC_WS_URL=https://ivod-preprod-srv01.xselcloud.com
# NEXT_PUBLIC_MINIO_URL n'est PAS utilisé pour AFFICHER les assets en prod : le
# front construit des URLs same-origin /media?bucket=...&key=... proxifiées
# par l'API (apps/web/lib/utils/assets.ts) pour la LECTURE. MinIO est en
# revanche exposé via /ivod-videos/ et /ivod-assets/ (nginx.prod.conf) pour
# les presigned PUT/GET d'UPLOAD direct navigateur (MinioService) — ce n'est
# pas la même chose qu'une exposition MinIO "généraliste". Cette variable ne
# sert qu'au CSP img-src/media-src (next.config.ts) ; laisser vide/commentée
# est sans risque.
# NEXT_PUBLIC_MINIO_URL=
# NEXT_PUBLIC_APP_URL=https://ivod-preprod-srv01.xselcloud.com
# NEXT_PUBLIC_APP_NAME=iVOD
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── Secrets CI/CD (GitHub Actions — à définir dans Settings → Secrets) ───────
# PROD_HOST=<IP VPS>
# PROD_USER=deploy
# PROD_SSH_KEY=<clé privée RSA>
# PROD_PORT=22
# PROD_APP_DIR=/opt/ivod
