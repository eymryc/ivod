{
  "name": "@ivod/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset --force",
    "prisma:refresh": "prisma migrate reset --force && npm run prisma:seed:all",
    "prisma:seed:categories": "node prisma/seed-categories.js",
    "prisma:seed:rbac": "node prisma/seed-rbac.js",
    "prisma:seed:rightsholders": "node prisma/seed-rightsholders.js",
    "prisma:seed:users": "node prisma/seed-users.js",
    "prisma:seed:all": "node prisma/seed-categories.js && node prisma/seed-rbac.js && node prisma/seed-rightsholders.js && node prisma/seed-users.js",
    "prisma:studio": "prisma studio",
    "clean": "rm -rf dist tsconfig.build.tsbuildinfo"
  },
  "dependencies": {
    "@ivod/types": "*",
    "@mux/mux-node": "^12.8.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/schedule": "^4.0.1",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^10.3.0",
    "@prisma/client": "^5.14.0",
    "@types/nodemailer": "^7.0.11",
    "@upstash/redis": "^1.31.0",
    "axios": "^1.7.2",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.1.0",
    "nodemailer": "^6.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^16.0.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^5.14.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  }
}
