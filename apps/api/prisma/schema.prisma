  uniqueViewers         BigInt   @default(0)
  totalWatchTimeSeconds BigInt   @default(0)
  averageWatchTimeSec   Int      @default(0)
  completionRate        Float    @default(0)
  likeCount             Int      @default(0)
  favoriteCount         Int      @default(0)
  commentCount          Int      @default(0)
  reviewCount           Int      @default(0)
  averageRating         Float    @default(0)
  popularityScore       Float    @default(0)
  updatedAt             DateTime @updatedAt

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("content_stats")
}

model UserBehavior {
  id        String   @id @default(cuid())
  profileId String
  action    String   // PLAY | PAUSE | SEEK | STOP | SEARCH | CLICK_CONTENT | SKIP_INTRO | SKIP_CREDITS | SCROLL
  contentId String?
  deviceId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  profile Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content Content? @relation(fields: [contentId], references: [id], onDelete: SetNull)
  device  Device?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([profileId, createdAt])
  @@map("user_behaviors")
}

model SearchHistory {
  id               String   @id @default(cuid())
  profileId        String
  query            String
  resultsCount     Int      @default(0)
  clickedContentId String?
  createdAt        DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt])
  @@map("search_history")
}

model TrendingSearch {
  id          String   @id @default(cuid())
  query       String
  searchCount Int      @default(0)
  period      String   // "1h" | "24h" | "7d"
  updatedAt   DateTime @updatedAt

  @@unique([query, period])
  @@map("trending_searches")
}

model Recommendation {
  id        String   @id @default(cuid())
  profileId String
  contentId String
  score     Float
  reason    String   // BECAUSE_YOU_WATCHED | POPULAR_IN_YOUR_COUNTRY | NEW_FROM_CREATOR | TRENDING | GENRE_MATCH
  algorithm String   @default("v1")
  expiresAt DateTime
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([profileId, contentId])
  @@index([profileId, score(sort: Desc)])
  @@map("recommendations")
}

model SearchIndex {
  contentId   String @id
  indexedText String // titre + description + tags + noms cast

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("search_index")
}

// ═══════════════════════════════════════════════════════════════
// ÉDITORIAL & MARKETING
// ═══════════════════════════════════════════════════════════════

model EditorialRail {
  id               String    @id @default(cuid())
  code             String    @unique
  title            String
  subtitle         String?
  surfaces         String[]
  type             String // query | personalized | editorial
  personalizedKind String?
  requiresAuth     Boolean   @default(false)
  hideIfEmpty      Boolean   @default(true)
  isActive         Boolean   @default(true)
  position         Int       @default(0)
  titleMode        String? // plain | with-section
  link             String?
  queryJson        Json?
  startsAt         DateTime?
  endsAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  items EditorialRailItem[]

  @@index([isActive, position])
  @@map("editorial_rails")
}

model EditorialRailItem {
  id        String   @id @default(cuid())
  railId    String
  contentId String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  rail    EditorialRail @relation(fields: [railId], references: [id], onDelete: Cascade)
  content Content       @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([railId, contentId])
  @@index([railId, position])
  @@map("editorial_rail_items")
}

model Banner {
  id                   String    @id @default(cuid())
  bannerType           String    @default("EDITORIAL") // EDITORIAL | CONTENT
  title                String
  subtitle             String?
  contentId            String?
  imageObjectKey       String?
  imageObjectKeyMobile String?
  linkUrl              String?
  ctaLabel             String?
  ctaStyle             String    @default("PRIMARY") // PRIMARY | GHOST | PREMIUM
  badgeText            String?
  position             Int       @default(0)
  targetPlanIds        String[]
  countryIds           String[]
  isActive             Boolean   @default(true)
  startsAt             DateTime?
  endsAt               DateTime?
  impressionCount      Int       @default(0)
  clickCount           Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  content Content? @relation(fields: [contentId], references: [id], onDelete: SetNull)

  @@map("banners")
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  typeId      String
  startsAt    DateTime
  endsAt      DateTime
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  type RefCampaignType @relation(fields: [typeId], references: [id])

  @@map("campaigns")
}

model Award {
  id        String   @id @default(cuid())
  typeId    String
  name      String
  category  String?
  year      Int
  createdAt DateTime @default(now())

  type          RefAwardType   @relation(fields: [typeId], references: [id])
  contentAwards ContentAward[]

  @@map("awards")
}

model ContentAward {
  contentId String
  awardId   String
  won       Boolean @default(true) // true = gagné, false = nommé

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  award   Award   @relation(fields: [awardId], references: [id], onDelete: Cascade)

  @@id([contentId, awardId])
  @@map("content_awards")
}

model ContentStatusHistory {
  id              String   @id @default(cuid())
  contentId       String
  oldStatus       String
  newStatus       String
  changedByUserId String?
  comment         String?
  createdAt       DateTime @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId, createdAt])
  @@map("content_status_history")
}

model ModerationQueue {
  id               String   @id @default(cuid())
  contentId        String
  priorityId       String
  assignedToUserId String?
  notes            String?
  statusId         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  content  Content               @relation(fields: [contentId], references: [id], onDelete: Cascade)
  priority RefModerationPriority @relation(fields: [priorityId], references: [id])
  status   RefModerationStatus   @relation(fields: [statusId], references: [id])

  @@map("moderation_queue")
}

// ═══════════════════════════════════════════════════════════════
// PUBLICITÉ — AVOD (Phase 2)
// ═══════════════════════════════════════════════════════════════

model Ad {
  id                 String   @id @default(cuid())
  title              String
  videoObjectKey     String
  thumbnailObjectKey String?
  durationSec        Int
  clickUrl           String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  adCampaigns   AdCampaign[]
  adImpressions AdImpression[]

  @@map("ads")
}

model AdCampaign {
  id        String   @id @default(cuid())
  adId      String
  name      String
  startsAt  DateTime
  endsAt    DateTime
  budget    Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@map("ad_campaigns")
}

model AdImpression {
  id        String   @id @default(cuid())
  adId      String
  profileId String
  clicked   Boolean  @default(false)
  viewedAt  DateTime @default(now())

  ad      Ad      @relation(fields: [adId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([adId, viewedAt])
  @@map("ad_impressions")
}

// ═══════════════════════════════════════════════════════════════
// LIVE STREAMING (Phase 2)
// ═══════════════════════════════════════════════════════════════

model LiveStream {
  id                 String    @id @default(cuid())
  creatorId          String
  title              String
  description        String?
  streamKey          String    @unique
  playbackUrl        String?
  statusId           String
  viewerCount        Int       @default(0)
  thumbnailObjectKey String?
  scheduledStartAt   DateTime?
  startedAt          DateTime?
  endedAt            DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  creator    Creator             @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  status     RefLiveStreamStatus @relation(fields: [statusId], references: [id])
  liveEvents LiveEvent[]

  @@map("live_streams")
}

model LiveEvent {
  id              String   @id @default(cuid())
  liveStreamId    String
  type            String   // CONCERT | MATCH | CONFERENCE | PREMIERE | OTHER
  ticketPriceFcfa Int?
  maxViewers      Int?
  createdAt       DateTime @default(now())

  liveStream LiveStream @relation(fields: [liveStreamId], references: [id], onDelete: Cascade)

  @@map("live_events")
}
