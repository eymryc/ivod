generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// RÉFÉRENTIELS
// Tables de données stables, seed au démarrage
// ═══════════════════════════════════════════════════════════════

model RefLanguage {
  id        String   @id @default(cuid())
  code      String   @unique // fr, en, wo, bm, ha, yo, ig...
  label     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  subtitleTracks   SubtitleTrack[]
  audioTracks      AudioTrack[]
  profileLanguages Profile[]
  originalContents Content[]

  @@map("ref_languages")
}

model RefCountry {
  id        String   @id @default(cuid())
  isoCode   String   @unique // CI, SN, ML, FR, US...
  label     String
  region    String   @default("OTHER") // WEST_AFRICA | CENTRAL_AFRICA | NORTH_AFRICA | EUROPE | DIASPORA | OTHER
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  rightsholders       Rightsholder[]
  originContents      Content[]
  distributionRegions DistributionRegion[]
  geoRestrictions     GeoRestriction[]
  taxes               Tax[]
  personBirths        Person[]

  @@map("ref_countries")
}

model RefCurrency {
  id        String   @id @default(cuid())
  code      String   @unique // XOF, USD, EUR, GBP
  label     String
  symbol    String
  decimals  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  exchangeRatesFrom ExchangeRate[] @relation("ExchangeRateFrom")
  exchangeRatesTo   ExchangeRate[] @relation("ExchangeRateTo")

  @@map("ref_currencies")
}

model RefGenre {
  id        String   @id @default(cuid())
  code      String   @unique // ACTION, DRAMA, COMEDIE, DOCUMENTAIRE, ANIMATION, THRILLER, ROMANCE, HORREUR, SF, HISTORIQUE
  label     String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  contentGenres ContentGenre[]

  @@map("ref_genres")
}

model RefContentType {
  id       String @id @default(cuid())
  code     String @unique // FILM | SERIE | WEB_SERIE | DOCUMENTAIRE | ANIMATION | SHORT
  typeCode String @unique // utilisé en logique applicative
  label    String

  contents Content[]

  @@map("ref_content_types")
}

model RefContentStatus {
  id    String @id @default(cuid())
  code  String @unique // DRAFT | PENDING_REVIEW | APPROVED | REJECTED | PUBLISHED | ARCHIVED
  label String

  contents Content[]
  episodes Episode[]

  @@map("ref_content_statuses")
}

model RefContentVisibility {
  id    String @id @default(cuid())
  code  String @unique // PUBLIC | SUBSCRIBERS_ONLY | PPV | PRIVATE
  label String

  contents Content[]

  @@map("ref_content_visibilities")
}

model RefMaturityRating {
  id    String @id @default(cuid())
  code  String @unique // ALL | MINUS_12 | MINUS_16 | MINUS_18
  label String
  order Int    @default(0) // pour comparer les niveaux

  contents        Content[]
  profiles        Profile[]
  parentalControls ParentalControl[]

  @@map("ref_maturity_ratings")
}

model RefUserRole {
  id    String @id @default(cuid())
  code  String @unique // VIEWER | CREATOR | ADMIN | MODERATOR | FINANCE | DISTRIBUTOR
  label String

  userRoles UserRole[]

  @@map("ref_user_roles")
}

model RefUserPlan {
  id                  String   @id @default(cuid())
  code                String   @unique // FREE | PASS_24H | PASS_WEEK | PREMIUM | BASIC (legacy)
  label               String
  tagline             String?  // Sous-titre affiché boutique (ex. « Sans pub · 30 jours »)
  priceFcfaMonthly    Int      @default(0) // Prix du pass en FCFA (quel que soit la durée)
  billingDays         Int      @default(30) // Durée d'accès : 1, 7, 30…
  maxScreens          Int      @default(1)
  videoQuality        String   @default("SD") // SD | HD | FHD | UHD
  hasAds              Boolean  @default(true)
  maxOfflineDownloads Int      @default(0)
  hasExclusiveAccess  Boolean  @default(false)
  isActive            Boolean  @default(true)
  showInStore         Boolean  @default(true) // Affiché page abonnement (FREE = false)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  userSubscriptions UserSubscription[]

  @@map("ref_user_plans")
}

model RefSubscriptionStatus {
  id    String @id @default(cuid())
  code  String @unique // ACTIVE | EXPIRED | CANCELLED | PAUSED | TRIAL
  label String

  userSubscriptions UserSubscription[]

  @@map("ref_subscription_statuses")
}

model RefPaymentProvider {
  id        String   @id @default(cuid())
  code      String   @unique // PAYSTACK | FREE (+ legacy rows en BDD)
  label     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  userSubscriptions UserSubscription[]
  payments          Payment[]

  @@map("ref_payment_providers")
}

model RefPaymentStatus {
  id    String @id @default(cuid())
  code  String @unique // PENDING | COMPLETED | FAILED | REFUNDED | CANCELLED
  label String

  payments     Payment[]
  transactions Transaction[] @relation("TransactionStatus")

  @@map("ref_payment_statuses")
}

model RefRightsholderType {
  id    String @id @default(cuid())
  code  String @unique // PRODUCER | PRODUCTION_COMPANY | DISTRIBUTOR | DIRECTOR | CO_PRODUCER
  label String

  rightsholders Rightsholder[]

  @@map("ref_rightsholder_types")
}

model RefMonetizationType {
  id    String @id @default(cuid())
  code  String @unique // SVOD | TVOD | AVOD | FREE
  label String

  contentRights ContentRight[]

  @@map("ref_monetization_types")
}

model RefTerritoryCode {
  id    String @id @default(cuid())
  code  String @unique // CI | SN | ML | BF | TG | BJ | GN | NE | CM | UEMOA | AFRICA | WORLD | DIASPORA
  label String

  contentRights ContentRight[]

  @@map("ref_territory_codes")
}

model RefCrewRole {
  id    String @id @default(cuid())
  code  String @unique // DIRECTOR | SCREENWRITER | PRODUCER | EDITOR | COMPOSER | CINEMATOGRAPHER | COSTUME | SOUND
  label String

  contentCrews ContentCrew[]

  @@map("ref_crew_roles")
}

model RefAwardType {
  id    String @id @default(cuid())
  code  String @unique // FESPACO | CLAP_IVOIRE | OSCARS | CANNES | CESAR | BAFTA | GOLDEN_GLOBE
  label String

  awards Award[]

  @@map("ref_award_types")
}

model RefReportReason {
  id      String          @id @default(cuid())
  code    String          @unique // INAPPROPRIATE | SPAM | COPYRIGHT | MISINFORMATION | OTHER
  label   String
  reports ContentReport[]

  @@map("ref_report_reasons")
}

model RefReportStatus {
  id      String          @id @default(cuid())
  code    String          @unique // PENDING | REVIEWED | DISMISSED | ACTIONED
  label   String
  reports ContentReport[]

  @@map("ref_report_statuses")
}

model RefModerationPriority {
  id     String            @id @default(cuid())
  code   String            @unique // NORMAL | HIGH | URGENT
  label  String
  queues ModerationQueue[]

  @@map("ref_moderation_priorities")
}

model RefModerationStatus {
  id     String            @id @default(cuid())
  code   String            @unique // PENDING | IN_REVIEW | DONE
  label  String
  queues ModerationQueue[]

  @@map("ref_moderation_statuses")
}

model RefSecurityLogAction {
  id   String        @id @default(cuid())
  code String        @unique // PASSWORD_CHANGE | FAILED_LOGIN | ACCOUNT_LOCKED | SUSPICIOUS_ACCESS | MFA_ENABLED | TOKEN_REVOKED
  label String
  logs SecurityLog[]

  @@map("ref_security_log_actions")
}

model RefTransactionType {
  id           String        @id @default(cuid())
  code         String        @unique // DEBIT | CREDIT | REFUND | CHARGEBACK
  label        String
  transactions Transaction[]

  @@map("ref_transaction_types")
}

model RefInvoiceStatus {
  id       String    @id @default(cuid())
  code     String    @unique // DRAFT | ISSUED | PAID | VOID
  label    String
  invoices Invoice[]

  @@map("ref_invoice_statuses")
}

model RefRefundStatus {
  id      String   @id @default(cuid())
  code    String   @unique // REQUESTED | APPROVED | PROCESSED | REJECTED
  label   String
  refunds Refund[]

  @@map("ref_refund_statuses")
}

model RefRevenueStatementStatus {
  id         String             @id @default(cuid())
  code       String             @unique // DRAFT | LOCKED | PAID
  label      String
  statements RevenueStatement[]

  @@map("ref_revenue_statement_statuses")
}

model RefBeneficiaryType {
  id         String             @id @default(cuid())
  code       String             @unique // RIGHTSHOLDER | CREATOR | PARTNER
  label      String
  statements RevenueStatement[]

  @@map("ref_beneficiary_types")
}

model RefContentRightStatus {
  id     String         @id @default(cuid())
  code   String         @unique // ACTIVE | EXPIRED | SUSPENDED
  label  String
  rights ContentRight[]

  @@map("ref_content_right_statuses")
}

model RefMediaAssetType {
  id     String       @id @default(cuid())
  code   String       @unique // THUMBNAIL | POSTER | BANNER | TRAILER | CLIP | SCREENSHOT
  label  String
  assets MediaAsset[]

  @@map("ref_media_asset_types")
}

model RefLiveStreamStatus {
  id      String       @id @default(cuid())
  code    String       @unique // SCHEDULED | LIVE | ENDED | CANCELLED
  label   String
  streams LiveStream[]

  @@map("ref_live_stream_statuses")
}

model RefCampaignType {
  id        String     @id @default(cuid())
  code      String     @unique // PROMO_CODE | EMAIL | PUSH | IN_APP_BANNER
  label     String
  campaigns Campaign[]

  @@map("ref_campaign_types")
}

// ═══════════════════════════════════════════════════════════════
// UTILISATEURS & PROFILS
// ═══════════════════════════════════════════════════════════════

model User {
  id                       String    @id @default(cuid())
  email                    String    @unique
  phone                    String?   @unique
  passwordHash             String?
  firstName                String    @default("")
  lastName                 String    @default("")
  name                     String
  avatarUrl                String?
  isActive                 Boolean   @default(true)
  mustChangePassword       Boolean   @default(false)
  passwordSetupTokenSha256 String?   @unique
  passwordSetupExpiresAt   DateTime?
  emailMarketing           Boolean   @default(true)
  emailNotifications       Boolean   @default(true)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  profiles          Profile[]
  userRoles         UserRole[]
  userPermissions   UserPermission[]
  creator           Creator?
  userSubscriptions UserSubscription[]
  payments          Payment[]
  downloads         Download[]
  notifications     Notification[]
  follows           Follow[]
  uploadedContents  Content[]          @relation("UploadedByUser")
  loginHistory      LoginHistory[]
  deviceSessions    DeviceSession[]
  securityLogs      SecurityLog[]
  devices           Device[]
  invoices          Invoice[]
  contentReports    ContentReport[]    @relation("ReviewedByUser")
  moderatedComments Comment[]          @relation("ModeratedByUser")

  @@map("users")
}

model Profile {
  id               String   @id @default(cuid())
  userId           String
  name             String
  avatarUrl        String?
  isKids           Boolean  @default(false)
  isDefault        Boolean  @default(false)
  pin              String?  // code PIN haché
  languageCode     String?
  maturityRatingId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  language       RefLanguage?       @relation(fields: [languageCode], references: [code])
  maturityRating RefMaturityRating? @relation(fields: [maturityRatingId], references: [id])

  parentalControl   ParentalControl?
  profilePreference ProfilePreference?
  watchHistories    WatchHistory[]
  watchSessions     WatchSession[]
  favorites         Favorite[]
  contentLikes      ContentLike[]
  comments          Comment[]
  contentReviews    ContentReview[]
  contentReports    ContentReport[]
  recommendations   Recommendation[]
  userBehaviors     UserBehavior[]
  searchHistories   SearchHistory[]
  adImpressions     AdImpression[]
  contentViews      ContentView[]

  @@map("profiles")
}

model ParentalControl {
  id                   String   @id @default(cuid())
  profileId            String   @unique
  maxMaturityRatingId  String?
  blockedGenreCodes    String[]
  restrictedHoursStart Int?
  restrictedHoursEnd   Int?
  requirePin           Boolean  @default(false)

  profile           Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  maxMaturityRating RefMaturityRating? @relation(fields: [maxMaturityRatingId], references: [id])

  @@map("parental_controls")
}

model ProfilePreference {
  id             String  @id @default(cuid())
  profileId      String  @unique
  autoplay       Boolean @default(true)
  skipIntro      Boolean @default(false)
  skipCredits    Boolean @default(false)
  defaultQuality String  @default("auto")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("profile_preferences")
}

model Role {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId      String   @id
  roleId      String
  roleRefCode String?
  createdAt   DateTime @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleRef RefUserRole? @relation(fields: [roleRefCode], references: [code])

  @@map("user_roles")
}

model UserPermission {
  userId       String
  permissionId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

model Device {
  id          String   @id @default(cuid())
  userId      String
  deviceType  String   // MOBILE | TABLET | TV | WEB | DESKTOP
  deviceName  String?
  os          String?
  osVersion   String?
  appVersion  String?
  fingerprint String?
  createdAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceTokens   DeviceToken[]
  deviceSessions DeviceSession[]
  loginHistory   LoginHistory[]
  watchSessions  WatchSession[]
  userBehaviors  UserBehavior[]
  contentViews   ContentView[]

  @@map("devices")
}

model DeviceToken {
  id        String   @id @default(cuid())
  deviceId  String
  token     String   @unique
  platform  String   // ANDROID | IOS | WEB
  updatedAt DateTime @updatedAt

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}

model DeviceSession {
  id             String   @id @default(cuid())
  userId         String
  deviceId       String
  token          String   @unique
  isActive       Boolean  @default(true)
  lastActivityAt DateTime @default(now())
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("device_sessions")
}

model LoginHistory {
  id          String   @id @default(cuid())
  userId      String
  ipAddress   String?
  userAgent   String?
  deviceId    String?
  countryCode String?
  cityName    String?
  success     Boolean  @default(true)
  createdAt   DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("login_history")
}

model SecurityLog {
  id        String   @id @default(cuid())
  userId    String?
  actionId  String
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  user   User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  action RefSecurityLogAction @relation(fields: [actionId], references: [id])

  @@index([userId, createdAt])
  @@map("security_logs")
}

// ═══════════════════════════════════════════════════════════════
// CRÉATEURS & RIGHTSHOLDERS
// ═══════════════════════════════════════════════════════════════

model Creator {
  id              String    @id @default(cuid())
  userId          String    @unique
  stageName       String
  bio             String?
  avatarObjectKey String?
  bannerObjectKey String?
  verified        Boolean   @default(false)
  verifiedAt      DateTime?
  subscriberCount Int       @default(0)
  totalEarned     Int       @default(0) // FCFA
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contents    Content[]
  followers   Follow[]
  liveStreams  LiveStream[]

  @@map("creators")
}

model Rightsholder {
  id            String   @id @default(cuid())
  typeId        String
  displayName   String
  legalName     String?
  email         String?
  phone         String?
  countryId     String?
  logoObjectKey String?
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  type    RefRightsholderType @relation(fields: [typeId], references: [id])
  country RefCountry?         @relation(fields: [countryId], references: [id])

  primaryContents       Content[]          @relation("ContentPrimaryRightsholder")
  distributedContents   Content[]          @relation("ContentDistributor")
  ownedContracts        RightsContract[]   @relation("ContractRightsholder")
  distributionContracts RightsContract[]   @relation("ContractDistributor")
  revenueStatements     RevenueStatement[]

  @@index([typeId, displayName])
  @@map("rightsholders")
}

// ═══════════════════════════════════════════════════════════════
// CONTENU
// ═══════════════════════════════════════════════════════════════

model Content {
  id                    String    @id @default(cuid())
  creatorId             String
  uploadedByUserId      String
  primaryRightsholderId String
  distributorId         String?
  title                 String
  slug                  String    @unique
  description           String?
  shortDescription      String?
  contentTypeId         String
  statusId              String
  visibilityId          String
  maturityRatingId      String?
  countryOfOriginId     String?
  originalLanguageCode  String?
  releaseYear           Int?
  duration              Int?      // secondes (nullable pour séries)
  isExclusive           Boolean   @default(false)
  ppvPrice              Int?      // FCFA, TVOD uniquement
  trailerUrl            String?
  tags                  String[]
  releaseDate           DateTime?
  publishedAt           DateTime?
  rejectionReason       String?
  viewCount             Int       @default(0)
  likeCount             Int       @default(0)
  averageRating         Float     @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  creator             Creator              @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  uploadedBy          User                 @relation("UploadedByUser", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  primaryRightsholder Rightsholder         @relation("ContentPrimaryRightsholder", fields: [primaryRightsholderId], references: [id], onDelete: Restrict)
  distributor         Rightsholder?        @relation("ContentDistributor", fields: [distributorId], references: [id], onDelete: SetNull)
  contentType         RefContentType       @relation(fields: [contentTypeId], references: [id])
  status              RefContentStatus     @relation(fields: [statusId], references: [id])
  visibility          RefContentVisibility @relation(fields: [visibilityId], references: [id])
  maturityRating      RefMaturityRating?   @relation(fields: [maturityRatingId], references: [id])
  countryOfOrigin     RefCountry?          @relation(fields: [countryOfOriginId], references: [id])
  originalLanguage    RefLanguage?         @relation(fields: [originalLanguageCode], references: [code])

  contentGenres        ContentGenre[]
  seasons              Season[]
  episodes             Episode[]
  mediaAssets          MediaAsset[]
  videoAssets          VideoAsset[]
  subtitleTracks       SubtitleTrack[]
  audioTracks          AudioTrack[]
  contentCasts         ContentCast[]
  contentCrews         ContentCrew[]
  distributions        Distribution[]
  geoRestrictions      GeoRestriction[]
  contentRights        ContentRight[]
  revenueStatements    RevenueStatement[]
  royalties            Royalty[]
  watchHistories       WatchHistory[]
  watchSessions        WatchSession[]
  favorites            Favorite[]
  contentLikes         ContentLike[]
  comments             Comment[]
  contentReviews       ContentReview[]
  contentReports       ContentReport[]
  downloads            Download[]
  recommendations      Recommendation[]
  userBehaviors        UserBehavior[]
  contentViews         ContentView[]
  contentStats         ContentStats?
  contentAwards        ContentAward[]
  banners              Banner[]
  editorialRailItems   EditorialRailItem[]
  statusHistories      ContentStatusHistory[]
  moderationQueues     ModerationQueue[]
  searchIndex          SearchIndex?
  ppvPayments          Payment[]

  @@index([creatorId, statusId])
  @@index([slug])
  @@map("contents")
}

model ContentGenre {
  contentId String
  genreId   String

  content Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  genre   RefGenre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([contentId, genreId])
  @@map("content_genres")
}

model Season {
  id              String   @id @default(cuid())
  contentId       String
  number          Int
  title           String?
  description     String?
  posterObjectKey String?
  releaseYear     Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  content  Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  episodes Episode[]

  @@unique([contentId, number])
  @@map("seasons")
}

model Episode {
  id                 String   @id @default(cuid())
  contentId          String
  seasonId           String?
  seasonNumber       Int
  episodeNumber      Int
  title              String
  description        String?
  thumbnailObjectKey String?
  duration           Int      // secondes
  statusId           String
  viewCount          Int      @default(0)
  publishedAt        DateTime?
  rejectionReason    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  content        Content          @relation(fields: [contentId], references: [id], onDelete: Cascade)
  season         Season?          @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  status         RefContentStatus @relation(fields: [statusId], references: [id])
  videoAssets    VideoAsset[]
  mediaAssets    MediaAsset[]
  subtitleTracks SubtitleTrack[]
  audioTracks    AudioTrack[]
  watchHistories WatchHistory[]
  watchSessions  WatchSession[]
  contentViews   ContentView[]
  downloads      Download[]
  contentCasts   ContentCast[]
  contentCrews   ContentCrew[]

  @@unique([contentId, seasonNumber, episodeNumber])
  @@map("episodes")
}

model MediaAsset {
  id            String   @id @default(cuid())
  contentId     String
  episodeId     String?
  typeId        String
  objectKey     String   // chemin MinIO
  mimeType      String?
  sizeBytes     BigInt?
  width         Int?
  height        Int?
  languageCode  String?
  /// TEASER | STANDARD | THEATRICAL | FINAL (surtout pour type TRAILER)
  promoVariant  String?  @map("promo_variant")
  durationSec   Int?     @map("duration_sec")
  label         String?
  sortOrder     Int      @default(0) @map("sort_order")
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())

  content Content           @relation(fields: [contentId], references: [id], onDelete: Cascade)
  episode Episode?          @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  type    RefMediaAssetType @relation(fields: [typeId], references: [id])

  @@index([contentId, typeId, isPrimary])
  @@map("media_assets")
}

