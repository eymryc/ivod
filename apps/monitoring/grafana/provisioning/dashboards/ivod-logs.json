{
  "uid": "ivod-logs",
  "title": "iVOD — Logs (Loki)",
  "tags": ["ivod", "logs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Volume de logs par conteneur",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki-ds" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({container=~\"ivod-.+\"}[1m]))",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Logs niveau ERROR (API + worker)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki-ds" },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{container=~\"ivod-api-.+-prod|ivod-video-worker-prod\"} |= \"ERROR\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Tous les logs API (1/2)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "loki", "uid": "loki-ds" },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{container=~\"ivod-api-.+-prod\"}",
          "refId": "A"
        }
      ]
    }
  ]
}
