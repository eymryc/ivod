{
  "uid": "ivod-infra",
  "title": "iVOD — Infra (hôte + conteneurs)",
  "tags": ["ivod", "infra"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU hôte",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "RAM hôte",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "expr": "100 - ((node_memory_MemAvailable_bytes * 100) / node_memory_MemTotal_bytes)",
          "legendFormat": "RAM %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Disque hôte (/)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} * 100) / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"})",
          "legendFormat": "Disque %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Load average (1m/5m/15m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        { "expr": "node_load1", "legendFormat": "1m", "refId": "A" },
        { "expr": "node_load5", "legendFormat": "5m", "refId": "B" },
        { "expr": "node_load15", "legendFormat": "15m", "refId": "C" }
      ]
    },
    {
      "id": 5,
      "title": "CPU par conteneur",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"ivod-.+\"}[5m])) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Mémoire par conteneur",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"ivod-.+\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    }
  ]
}
