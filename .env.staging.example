# ═══════════════════════════════════════════════════════════════════════════════
# STAGING — Toutes les variables (infra + API)
# ═══════════════════════════════════════════════════════════════════════════════
# Copier ce fichier : cp .env.staging.example .env.staging
# NE PAS commiter .env.staging (dans .gitignore)
# ───────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=ivod_staging
POSTGRES_USER=ivod
POSTGRES_PASSWORD=staging_postgres_password

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=staging_redis_password

# ── MinIO ──────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=staging_minio_password
MINIO_BUCKET=ivod-staging
# URL publique de MinIO (pour les presigned URLs du navigateur)
MINIO_PRESIGN_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_BASE_URL=http://localhost:9000/ivod-staging

# ── Ports ──────────────────────────────────────────────────────────────────────
API_PORT=3000
WEB_PORT=3001

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=staging_jwt_secret_minimum_32_chars_xxxxxxxxxxxxxx
JWT_EXPIRES_IN=7d

# ── URL publiques ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001
API_PUBLIC_URL=http://localhost:3000
# Variable baked dans le build Next.js
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# ── Video ──────────────────────────────────────────────────────────────────────
VIDEO_UPLOAD_PROVIDER=minio
HLS_PLAYBACK_MODE=proxy
TRANSCODE_LADDER_PRESET=balanced
TRANSCODE_MAX_HEIGHT=1080

# ── Mux (si provider=mux) ──────────────────────────────────────────────────────
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret
MUX_WEBHOOK_SECRET=your_mux_webhook_secret
MUX_SIGNING_KEY_ID=your_signing_key_id
MUX_SIGNING_PRIVATE_KEY=your_signing_private_key

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM=price_staging_premium
STRIPE_PRICE_PREMIUM_PLUS=price_staging_premium_plus

# ── CinetPay ───────────────────────────────────────────────────────────────────
CINETPAY_API_KEY=your_staging_api_key
CINETPAY_SITE_ID=your_staging_site_id

# ── SMTP ───────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.staging.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@staging.ivod.ci
MAIL_PASSWORD=smtp_password
MAIL_FROM_ADDRESS=noreply@staging.ivod.ci
MAIL_FROM_NAME=iVOD Staging
MAIL_ADMIN_NOTIFICATION_EMAILS=dev@ivod.ci

# ── OneSignal (push) ───────────────────────────────────────────────────────────
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_API_KEY=your_onesignal_api_key

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=iVOD Staging
NODE_ENV=staging
PORT=3000
