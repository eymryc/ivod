# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION — Toutes les variables (infra + API)
# ═══════════════════════════════════════════════════════════════════════════════
# Copier ce fichier : cp .env.prod.example .env.prod
# NE PAS commiter .env.prod — injecter via CI/CD (GitHub Actions secrets, etc.)
# ───────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (si DB locale Docker) ──────────────────────────────────────────
# Si base externe (Supabase, RDS…) : définir DATABASE_URL directement ci-dessous
# et supprimer/commenter les variables POSTGRES_*
POSTGRES_DB=ivod
POSTGRES_USER=ivod
POSTGRES_PASSWORD=CHANGE_ME_VERY_STRONG_PASSWORD

# Alternative : URL directe (remplace les POSTGRES_* ci-dessus)
# DATABASE_URL=postgresql://user:pass@host:5432/ivod?sslmode=require

# ── Redis (si Redis local Docker) ──────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Alternative : URL directe (Upstash, Redis Cloud…)
# REDIS_URL=rediss://user:pass@hostname:6380

# ── MinIO (si MinIO local Docker) ──────────────────────────────────────────────
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET=ivod
# URL publique de MinIO (CDN ou reverse proxy devant MinIO)
MINIO_PRESIGN_ENDPOINT=https://storage.ivod.ci
MINIO_PUBLIC_BASE_URL=https://storage.ivod.ci/ivod

# ── Ports ──────────────────────────────────────────────────────────────────────
# En prod les ports sont loopback (127.0.0.1) — accès via reverse proxy (nginx, Caddy)
API_PORT=3000
WEB_PORT=3001

# ── URL publiques ──────────────────────────────────────────────────────────────
FRONTEND_URL=https://www.ivod.ci
API_PUBLIC_URL=https://api.ivod.ci
# Variable baked dans le build Next.js (doit être l'URL HTTPS publique)
NEXT_PUBLIC_API_URL=https://api.ivod.ci/api/v1

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_SECRET_MINIMUM_64_CHARS
JWT_EXPIRES_IN=7d

# ── Video ──────────────────────────────────────────────────────────────────────
VIDEO_UPLOAD_PROVIDER=minio
HLS_PLAYBACK_MODE=proxy
TRANSCODE_LADDER_PRESET=balanced
TRANSCODE_MAX_HEIGHT=2160

# ── Mux (si provider=mux ou fallback) ─────────────────────────────────────────
MUX_TOKEN_ID=prod_mux_token_id
MUX_TOKEN_SECRET=prod_mux_token_secret
MUX_WEBHOOK_SECRET=prod_mux_webhook_secret
MUX_SIGNING_KEY_ID=prod_signing_key_id
MUX_SIGNING_PRIVATE_KEY=prod_signing_private_key

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM=price_prod_premium
STRIPE_PRICE_PREMIUM_PLUS=price_prod_premium_plus

# ── CinetPay ───────────────────────────────────────────────────────────────────
CINETPAY_API_KEY=prod_api_key
CINETPAY_SITE_ID=prod_site_id

# ── Redis Upstash REST (OTP store scalable — recommandé en prod) ───────────────
UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_rest_token

# ── SMTP ───────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.ivod.ci
MAIL_PORT=465
MAIL_USERNAME=noreply@ivod.ci
MAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
MAIL_FROM_ADDRESS=noreply@ivod.ci
MAIL_FROM_NAME=iVOD
MAIL_ADMIN_NOTIFICATION_EMAILS=admin@ivod.ci

# ── OneSignal (push) ───────────────────────────────────────────────────────────
ONESIGNAL_APP_ID=prod_onesignal_app_id
ONESIGNAL_API_KEY=prod_onesignal_api_key

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=iVOD
NODE_ENV=production
PORT=3000
