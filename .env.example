# =============================================================================
# .env RACINE — infrastructure Docker uniquement
# Copier vers .env à la racine du monorepo (à côté de docker-compose.dev.yml)
#
# Config API (JWT, Paystack, SMTP, Mux…) → apps/api/.env  (voir docs/ENV.md)
# Front Next.js → apps/web/.env.local
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=ivod
POSTGRES_PASSWORD=ivod
POSTGRES_DB=ivod
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_VIDEOS=ivod-videos
MINIO_BUCKET_ASSETS=ivod-assets

# ─── Ports exposés sur la machine hôte ───────────────────────────────────────
API_PORT=3000
ADMINER_PORT=8080

# ─── Ports web (prod) ────────────────────────────────────────────────────────
WEB_PORT=3001

# ─── Pipeline vidéo — surcharges optionnelles ─────────────────────────────────
# VIDEO_TWO_PHASE=true
# VIDEO_CPU_PARALLEL=2           # nb de ffmpeg CPU simultanés
# VIDEO_WORKER_CONCURRENCY=1     # nb de jobs BullMQ simultanés
# VIDEO_JOB_LOCK_MS=3600000
# VIDEO_JOB_LOCK_RENEW_MS=300000
# VIDEO_SINGLE_PASS_LADDER=true
# VIDEO_HW_ACCEL=none            # nvenc | vaapi | none
# VIDEO_WEBHOOK_URLS=
# VIDEO_WEBHOOK_SECRET=

# ─── Dev seulement ────────────────────────────────────────────────────────────
# MINIO_PUBLIC_ENDPOINT=localhost
# MINIO_PUBLIC_PORT=9000
# VIDEO_DEV_PROFILES=480p,720p   # optionnel : limite le ladder en dev
# VIDEO_FAST_MODE=true           # ultrafast + 480p/720p seulement

# ─── Prod uniquement ──────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://api.ivod.africa/api/v1  # baked dans le bundle web au build
