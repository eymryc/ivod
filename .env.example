# ═══════════════════════════════════════════════════════════════════════════════
# INFRASTRUCTURE — Variables partagées entre tous les services Docker
# ═══════════════════════════════════════════════════════════════════════════════
# Copier ce fichier : cp .env.example .env
# Ce fichier couvre l'infra (postgres, redis, minio) et les ports.
# Les secrets de l'API (JWT, Stripe, Mux, SMTP…) sont dans apps/api/.env
# ───────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=ivod
POSTGRES_USER=ivod
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────────────────────────
# Laisser vide pour désactiver l'auth (acceptable en dev local)
# REDIS_PASSWORD=change_me_redis_password
REDIS_PORT=6379

# ── MinIO (S3-compatible) ──────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET=ivod
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Ports des apps ─────────────────────────────────────────────────────────────
API_PORT=3000
WEB_PORT=3001
ADMINER_PORT=8080
